[Trigger]
Type = Path
Operation = Install
Operation = Upgrade
Target = usr/share/applications/org.gnome.Tour.desktop

[Action]
Description = Disabling GNOME Tour on live ISO...
When = PostTransaction
Exec = /bin/bash -c 'cp /usr/share/applications/org.gnome.Tour.desktop /etc/calamares/org.gnome.Tour.desktop.orig 2>/dev/null; printf "[Desktop Entry]\nType=Application\nName=Tour\nExec=/bin/true\nHidden=true\nNoDisplay=true\n" > /usr/share/applications/org.gnome.Tour.desktop'
